<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Home</title>
</head>
<body>
    <%- include('partials/header') %>
    <div class="container mt-3">

        <div class="card mb-3">
            <div class="card-body">
                <h4>Total Habits: <%= habits.length %></h4>
            </div>
        </div>

        <h1>Habits</h1>
        <ul>
            <% habits.forEach(h => { %>
        <li>
            <%= h.name %>

            <% if(h.completed){ %>
                ✅ Done
            <% } else { %>
                <a href="/habit/<%= h.id %>/done"  class="btn btn-success" > Mark Done </a>
            <% } %> 
        </li>
        <br>
        <a href="/add" class="btn btn-primary">Add Habit</a>
        <a href="/habit/<%= h.id %>/edit" class="btn btn-warning" >Edit</a>
        <a href="/habit/<%= h.id %>/delete" class="btn btn-danger" >Delete</a>

        <% }) %>
        </ul>
</body>
</html>